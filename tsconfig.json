{
  "extends": [
    "@tsconfig/recommended/tsconfig.json",
    "@tsconfig/node22/tsconfig.json"
  ],
  "compilerOptions": {
    "isolatedModules": true,
    "jsx": "react",
    "module": "preserve",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "sourceMap": true,
    "types": ["jest", "node"]
  },
  "include": ["src", "test", "scripts"],
  "exclude": ["**/__mocks__"]
}
